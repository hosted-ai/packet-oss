# =============================================================================
# GPU Cloud Dashboard - Open Source Edition
# Powered by hosted.ai (https://hosted.ai)
# =============================================================================
# Copy this file to .env.local to get started.
#
# Only DATABASE_URL is required to boot the app.
# All other settings can be configured in Admin > Platform Settings.
#
# IMPORTANT: GPU features require a hosted.ai account and API credentials.
# Visit https://hosted.ai to get your API URL and API key.
# =============================================================================

# --- Edition (do not change) ---
NEXT_PUBLIC_EDITION=oss

# --- Database (REQUIRED) ---
DATABASE_URL="mysql://gpucloud:password@localhost:3306/gpucloud"

# --- Application URL ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth Secrets (auto-generated if not set) ---
# Generate with: openssl rand -hex 32
# ADMIN_JWT_SECRET=
# CUSTOMER_JWT_SECRET=
# CRON_SECRET=

# --- All settings below are OPTIONAL ---
# You can configure these in Admin > Platform Settings instead of here.

# Stripe (billing features disabled without this)
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# GPU Backend - hosted.ai (REQUIRED for GPU features)
# Get your credentials at https://hosted.ai
# HOSTEDAI_API_URL=
# HOSTEDAI_API_KEY=

# Email (Emailit)
# EMAILIT_API_KEY=
# ADMIN_BCC_EMAIL=

# Email sender/recipient configuration
# EMAIL_FROM="Your Brand <no-reply@yourdomain.com>"
# SUPPORT_EMAIL=support@yourdomain.com
# SALES_EMAIL=sales@yourdomain.com
# ONBOARDING_EMAIL=onboarding@yourdomain.com
# STATUS_EMAIL_TO=team@yourdomain.com

# Support (Zammad)
# ZAMMAD_API_URL=
# ZAMMAD_API_TOKEN=

# CRM (Pipedrive)
# PIPEDRIVE_API_TOKEN=

# SSH Terminal WebSocket port
# SSH_WS_PORT=3002
